# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FLASK_SECRET_KEY=your-random-secret-key

# Nest Database (MySQL)
DB_HOST=db-mysql-nyc1-xxxxx-do-user-xxxxx-0.e.db.ondigitalocean.com
DB_PORT=25060
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=egelloc

# Nest DB Admin (for creating read-only users)
DB_ADMIN_USER=doadmin
DB_ADMIN_PASSWORD=your-doadmin-password

# Acquisition Database (PostgreSQL)
ACQ_DB_HOST=egelloc-ai-db-do-user-xxxxx-0.g.db.ondigitalocean.com
ACQ_DB_PORT=25060
ACQ_DB_NAME=defaultdb
ACQ_DB_ADMIN_USER=doadmin
ACQ_DB_ADMIN_PASSWORD=your-acq-doadmin-password

# Fathom API
FATHOM_API_KEY=your-fathom-api-key

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# ClickUp API
CLICKUP_API_KEY=your-clickup-api-key

# DigitalOcean API (for database firewall management)
DO_API_TOKEN_NEST=dop_v1_your-token
DO_DB_CLUSTER_NEST=your-cluster-uuid
DO_API_TOKEN_ACQ=dop_v1_your-token
DO_DB_CLUSTER_ACQ=your-cluster-uuid

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Shared Postgres (for deployed apps)
POSTGRES_USER=aihub_admin
POSTGRES_PASSWORD=aihub_local_dev

# Deploy Service (infra layer)
DEPLOY_SERVICE_URL=http://localhost:5001

# GitHub webhook secret (for auto-deploy on push)
GITHUB_WEBHOOK_SECRET=

# GitHub token for private repo access (fine-grained PAT, read-only)
# Create at: GitHub → Settings → Developer settings → Fine-grained tokens
# Permission: Contents: Read-only on your org's repos
GITHUB_TOKEN=
