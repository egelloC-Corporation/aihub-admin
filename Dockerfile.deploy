# Multi-stage: grab Docker CLI + Compose plugin from official image
FROM docker:27 AS docker-cli

FROM python:3.12-slim

# Docker CLI for building/managing app containers
COPY --from=docker-cli /usr/local/bin/docker /usr/local/bin/docker
# Compose plugin for self-deploy (docker compose up --build -d ...)
COPY --from=docker-cli /usr/local/libexec/docker/cli-plugins/docker-compose /usr/local/libexec/docker/cli-plugins/docker-compose

RUN apt-get update && \
    apt-get install -y --no-install-recommends git && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install --no-cache-dir flask psycopg2-binary python-dotenv

COPY scripts/ ./scripts/
COPY deploy_service.py .

EXPOSE 5001

CMD ["python", "deploy_service.py"]
